<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ACareClinic" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/brand_navy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.ACareClinic.Splash" parent="Theme.ACareClinic">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:statusBarColor">@color/brand_navy</item>
    </style>

    <!-- Card style dùng trong toàn app -->
    <style name="Widget.ACare.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
    </style>

    <!-- Chip trạng thái -->
    <style name="Widget.ACare.Chip.Status" parent="Widget.Material3.Chip.Assist">
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

    <!-- Button primary -->
    <style name="Widget.ACare.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Button outline -->
    <style name="Widget.ACare.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/primary</item>
    </style>
</resources>
